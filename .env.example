# 网易邮箱配置（可选，也可在界面中填写）
# EMAIL_ADDRESS=your_email@163.com
# IMAP_SERVER=imap.163.com
# IMAP_PORT=993
# IMAP_USE_SSL=true
# EMAIL_AUTH_CODE=your_client_auth_code_here

# OpenAI API 配置（可选，仅在启用 AI 分析时需要）
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4o

# 数据库路径（可选）
# DB_PATH=./mail_tracker.db
